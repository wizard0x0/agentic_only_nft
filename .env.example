# Private key of the deployer EOA wallet (for contract deployment only)
# This does NOT need to be an OKX Agentic Wallet — it's just the contract owner
DEPLOYER_PRIVATE_KEY=0x...

# OKLink API key for contract verification on OKLink explorer
OKLINK_API_KEY=

# IPFS/Arweave base URI for NFT metadata (set before mainnet deployment)
BASE_TOKEN_URI=ipfs://YOUR_CID_HERE/
